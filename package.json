{
  "name": "ai-powered-apps",
  "private": true,
  "epicshop": {
    "title": "Building AI-Powered Apps",
    "subtitle": "Build a streaming AI shopping assistant on top of a real React Router app",
    "githubRepo": "https://github.com/epicweb-dev/ai-powered-apps",
    "subdomain": "ai-powered-apps",
    "instructor": {
      "name": "Alem Tuzlak",
      "avatar": "/images/instructor.png",
      "𝕏": "AlemTuzlak"
    },
    "product": {
      "host": "www.epicweb.dev",
      "displayName": "EpicWeb.dev",
      "displayNameShort": "Epic Web"
    },
    "forms": {
      "workshop": "https://docs.google.com/forms/d/e/1FAIpQLSe8hQTf_CaAhrbYyaYBvgz6iicfMzDiKcLk6_ZjQWJip_-UNw/viewform?hl=en&embedded=true&entry.1841054081={workshopTitle}",
      "exercise": "https://docs.google.com/forms/d/e/1FAIpQLScNqiw2_F6j0oSuczCH6vkniT7glQxk39qvYn2IwN9IbOUiGA/viewform?hl=en&embedded=true&entry.240391449={workshopTitle}&entry.353813257={exerciseTitle}"
    }
  },
  "type": "module",
  "scripts": {
    "postinstall": "cd ./epicshop && pkgmgr install",
    "start": "pkgmgrx --prefix ./epicshop epicshop start",
    "dev": "pkgmgrx --prefix ./epicshop epicshop start",
    "test": "pkgmgr run test --silent --prefix playground",
    "test:e2e": "pkgmgr run test:e2e --silent --prefix playground",
    "test:e2e:dev": "pkgmgr run test:e2e:dev --silent --prefix playground",
    "test:e2e:run": "pkgmgr run test:e2e:run --silent --prefix playground",
    "setup": "pkgmgrx epicshop setup",
    "setup:custom": "node ./epicshop/setup-custom.ts",
    "lint": "oxlint --config .oxlintrc.json .",
    "format": "prettier --write .",
    "typecheck": "tsc -b",
    "validate:all": "npm-run-all --parallel --print-label --print-name --continue-on-error test:all lint typecheck"
  },
  "keywords": [],
  "author": "Kent C. Dodds <me@kentcdodds.com> (https://kentcdodds.com/)",
  "license": "GPL-3.0-only",
  "workspaces": [
    "exercises/*/*",
    "extra/*"
  ],
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=8.16.0",
    "git": ">=2.18.0"
  },
  "devDependencies": {
    "@epic-web/config": "1.24.1",
    "@tanstack/ai": "0.22.1",
    "@tanstack/ai-client": "0.13.0",
    "@tanstack/ai-event-client": "0.4.2",
    "@tanstack/ai-react": "0.12.1",
    "@types/node": "24.12.4",
    "oxlint": "1.67.0",
    "pkgmgr": "1.1.1",
    "prettier": "3.8.3",
    "typescript": "5.9.3"
  },
  "prettier": "@epic-web/config/prettier"
}
